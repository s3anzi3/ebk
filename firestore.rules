rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // public profiles (used for leaderboard names)
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // unique display-name registry. Doc id = lowercased name. A create only
    // succeeds when the doc doesn't exist yet (Firestore semantics) and updates
    // are forbidden, so two users can never hold the same name. Owners may
    // release their own name (delete).
    match /usernames/{nameKey} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if false;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // one doc per user per (sport, game): best + aggregate counts.
    // public read (leaderboards/dashboards), owner-only write, id must
    // match uid_sport_game so a user can only write their own rows.
    match /scores/{id} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && id == request.auth.uid + '_' + request.resource.data.sport + '_' + request.resource.data.game
        && request.resource.data.best is number
        && request.resource.data.plays is number;
      allow delete: if false;
    }
  }
}
